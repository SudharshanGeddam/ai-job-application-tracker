# .gitignore

# Node dependencies
node_modules/

# Environment variable files (contain secrets — never commit these)
.env
.env.local
.env.production

# Prisma generated client (platform-specific, regenerated on install)
src/generated/prisma

# Logs
*.log
npm-debug.log*
logs/

# Build output
dist/

# Test coverage reports
coverage/

# OS-specific files
.DS_Store
Thumbs.db

# Local scripts (dev utilities, not part of the app)
scripts/

# Test Scripts
test-endpoints.js
update-test.js

# Agents
docs/.agents
